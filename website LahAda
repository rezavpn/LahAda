      </div>
      <div class="banner-small banner-small-2">
        <h3>Member VIP</h3>
        <p>Diskon eksklusif tiap hari</p>
      </div>
    </div>
  </div>

  <!-- KATEGORI -->
  <section id="kategori">
    <div class="categories">
