          <span class="cat-name">Elektronik</span>
        </div>
        <div class="cat-item" onclick="filterCategory('fashion')">
          <div class="cat-icon" style="background:#FCE7F3;">👗</div>
          <span class="cat-name">Fashion</span>
        </div>
        <div class="cat-item" onclick="filterCategory('kecantikan')">
          <div class="cat-icon" style="background:#FEF9C3;">💄</div>
          <span class="cat-name">Kecantikan</span>
        </div>
        <div class="cat-item" onclick="filterCategory('rumah')">
          <div class="cat-icon" st